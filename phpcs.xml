<?xml version="1.0"?>
<ruleset name="WooDiviExtended">
  <description>PHP_CodeSniffer rules for WooDiviExtended plugin (WordPress)</description>

  <!-- Use WordPress Coding Standards if available -->
  <rule ref="WordPress"/>

  <!-- Exclude vendor and build artifacts -->
  <exclude-pattern>vendor/*</exclude-pattern>
  <exclude-pattern>node_modules/*</exclude-pattern>
  <exclude-pattern>assets/js/*.min.js</exclude-pattern>
  <exclude-pattern>assets/css/*.min.css</exclude-pattern>
</ruleset>
