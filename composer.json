{
  "name": "woocommerce/woodivi-extend",
  "description": "Extended features for WooCommerce with Divi integration",
  "version": "1.0.0",
  "license": "GPL-2.0-or-later",
  "authors": [
    {
      "name": "Hasan Tareq",
      "email": "hsntareq@gmail.com"
    }
  ],
  "require": {
    "php": ">=7.4"
  },
  "require-dev": {
    "squizlabs/php_codesniffer": "^3.7",
    "wp-coding-standards/wpcs": "^2.3"
  },
  "autoload": {
    "psr-4": {
      "WooDiviExtended\\": "src/"
    }
  },
  "config": {
    "allow-plugins": {
      "dealerdirect/phpcodesniffer-composer-installer": true
    }
  }

  ,
  "scripts": {
    "build-assets": "php bin/build-assets.php",
    "cs": "phpcs -p --standard=phpcs.xml",
    "cs-fix": "phpcbf --standard=phpcs.xml"
  }
}
